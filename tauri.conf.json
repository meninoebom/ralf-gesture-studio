{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RALF Gesture Studio",
  "version": "0.2.0",
  "identifier": "com.ralf.gesture-studio",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RALF Gesture Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
